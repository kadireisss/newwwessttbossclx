{
  "version": 2,
  "buildCommand": "vite build && npx esbuild server/vercel-entry.ts --bundle --platform=node --target=node20 --format=esm --outfile=api/index.mjs --packages=external",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/r/:path*", "destination": "/api" },
    { "source": "/maintenance", "destination": "/api" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
